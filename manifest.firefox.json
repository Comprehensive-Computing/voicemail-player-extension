{
  "manifest_version": 3,
  "name": "Voicemail Player",
  "version": "0.1.0",
  "description": "Transcodes MS GSM 6.10 WAV Gmail attachments into playable PCM WAV audio.",
  "icons": {
    "32": "img/Voicemail-Player-Extension-Icon-32x32.png",
    "64": "img/Voicemail-Player-Extension-Icon-64x64.png",
    "128": "img/Voicemail-Player-Extension-Icon-128x128.png"
  },
  "permissions": [
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "scripts": [
      "src/background.js"
    ],
    "type": "module"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; worker-src 'self'"
  },
  "content_scripts": [
    {
      "matches": [
        "https://mail.google.com/*"
      ],
      "js": [
        "src/content-script.js"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/page-proxy.js",
        "src/vendor/ffmpeg/index.js",
        "src/vendor/ffmpeg/classes.js",
        "src/vendor/ffmpeg/const.js",
        "src/vendor/ffmpeg/errors.js",
        "src/vendor/ffmpeg/types.js",
        "src/vendor/ffmpeg/utils.js",
        "src/vendor/ffmpeg/worker.js",
        "src/vendor/ffmpeg-core/ffmpeg-core.js",
        "src/vendor/ffmpeg-core/ffmpeg-core.wasm"
      ],
      "matches": [
        "https://mail.google.com/*"
      ]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "voicemail-player@comprehensive-computing.com",
      "strict_min_version": "128.0"
    }
  }
}
